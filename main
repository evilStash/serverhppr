local Players         = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local HttpService     = game:GetService("HttpService")
local LocalPlayer     = Players.LocalPlayer

request = request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request)

local function httpGet(url)
    local ok, result = pcall(function()
        return request({Url = url, Method = "GET"}).Body
    end)
    if ok and type(result) == "string" and #result > 0 then return result end
    local ok2, result2 = pcall(function() return game:HttpGet(url) end)
    if ok2 and type(result2) == "string" and #result2 > 0 then return result2 end
    return nil
end

local function httpPost(url, body)
    local ok, result = pcall(function()
        return request({
            Url     = url,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = body
        }).Body
    end)
    if ok and type(result) == "string" and #result > 0 then return result end
    return nil
end

local function fetchPlaceDetails(placeIds)
    local idStr = table.concat(placeIds, "&placeIds=")
    local body = httpGet("https://games.roblox.com/v1/games/multiget-place-details?placeIds=" .. idStr)
    if not body then return nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(body) end)
    if ok and type(data) == "table" then return data end
    return nil
end

local function fetchServers(placeId)
    local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?limit=100"
    local body = httpGet(url)
    if not body then return nil, "httpGet returned nil" end
    local ok, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok then return nil, "JSON parse failed" end
    if data.errors then
        local msg = data.errors[1] and data.errors[1].message or "unknown API error"
        return nil, "Roblox API error: " .. msg
    end
    return data, body
end

local friendPresenceMap = {}

local function fetchFriendPresences()
    friendPresenceMap = {}

    local friendsBody = httpGet(
        "https://friends.roblox.com/v1/users/" .. LocalPlayer.UserId .. "/friends"
    )
    if not friendsBody then return end
    local ok, friendsData = pcall(function() return HttpService:JSONDecode(friendsBody) end)
    if not ok or not friendsData or not friendsData.data then return end

    local friends = friendsData.data
    if #friends == 0 then return end

    local userIds  = {}
    local idToName = {}
    for _, f in ipairs(friends) do
        if f.id then
            table.insert(userIds, f.id)
            idToName[tostring(f.id)] = (f.displayName ~= "" and f.displayName) or f.name
        end
    end

    local presenceBody = httpPost(
        "https://presence.roblox.com/v1/presence/users",
        HttpService:JSONEncode({ userIds = userIds })
    )
    if not presenceBody then return end
    local ok2, presData = pcall(function() return HttpService:JSONDecode(presenceBody) end)
    if not ok2 or not presData or not presData.userPresences then return end

    for _, p in ipairs(presData.userPresences) do
        local instanceId = tostring(p.gameInstanceId or "")
        if instanceId ~= "" and instanceId ~= "nil" then
            if not friendPresenceMap[instanceId] then
                friendPresenceMap[instanceId] = {}
            end
            table.insert(friendPresenceMap[instanceId], {
                userId = p.userId,
                name   = idToName[tostring(p.userId)] or "Friend"
            })
        end
    end
end

