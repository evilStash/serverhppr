local function pingCol(p)
    if p < 80  then return C.good end
    if p < 150 then return C.warn end
    return C.bad
end
local function popCol(n, mx)
    local r = n / math.max(mx, 1)
    if r >= 0.9 then return C.bad end
    if r >= 0.6 then return C.warn end
    return C.good
end
local function setStatus(msg, col)
    if StatusLabel and StatusLabel.Parent then
        StatusLabel.Text = msg; StatusLabel.TextColor3 = col or C.muted
    end
end
local function clearScroll()
    for _, ch in ipairs(Scroll:GetChildren()) do
        if not ch:IsA("UIListLayout") and not ch:IsA("UIPadding") then ch:Destroy() end
    end
end

local function rebuildDropdown()
    for _, ch in ipairs(DropMenu:GetChildren()) do
        if ch:IsA("TextButton") then ch:Destroy() end
    end
    local itemH = 42
    DropMenu.Size = UDim2.new(1,0,0, #GAMES * itemH + 8 + (#GAMES-1)*3)
    for i, g in ipairs(GAMES) do
        local sel = (i == selectedGameIndex)
        local opt = btn({
            Text="", Size=UDim2.new(1,0,0,itemH),
            BackgroundColor3=sel and C.accentDark or C.surface,
            LayoutOrder=i, ZIndex=61
        }, DropMenu)
        corner(6, opt)
        local t = Instance.new("ImageLabel")
        t.Size=UDim2.new(0,26,0,26); t.Position=UDim2.new(0,8,0.5,-13)
        t.BackgroundColor3=C.border; t.BorderSizePixel=0
        t.ZIndex=62; t.ScaleType=Enum.ScaleType.Crop
        t.Image=g.imageId or ""; t.Parent=opt; corner(4, t)
        label({
            Text=g.name, Font=Enum.Font.GothamSemibold, TextSize=13,
            TextColor3=sel and C.accent or C.text,
            Position=UDim2.new(0,42,0,0), Size=UDim2.new(1,-42,1,0),
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=62
        }, opt)
        opt.MouseEnter:Connect(function()
            if i ~= selectedGameIndex then opt.BackgroundColor3=C.surfaceHov end
        end)
        opt.MouseLeave:Connect(function()
            opt.BackgroundColor3=(i==selectedGameIndex) and C.accentDark or C.surface
        end)
        opt.MouseButton1Click:Connect(function()
            selectedGameIndex=i
            DropLabel.Text=g.name; DropThumb.Image=g.imageId or ""
            DropMenu.Visible=false; Chevron.Text="v"
            rebuildDropdown(); clearScroll()
            setStatus("⏳ Loading servers...", C.muted)
            task.spawn(doLoadServers)
        end)
    end
end

local dropOpen = false
DropBtn2.MouseButton1Click:Connect(function()
    dropOpen=not dropOpen
    DropMenu.Visible=dropOpen
    Chevron.Text=dropOpen and "^" or "v"
end)

local function buildCard(server, idx)
    local ping    = math.floor(server.ping or 999)
    local playing = server.playing or 0
    local maxP    = server.maxPlayers or 20

    local isCurrentServer = tostring(server.id) == tostring(game.JobId)
    local friendsHere     = friendPresenceMap[tostring(server.id)] or {}
    local hasFriends      = #friendsHere > 0

    local hasVisitorRow = isCurrentServer or hasFriends
    local cardH         = hasVisitorRow and 94 or 64

    local cardBg     = isCurrentServer and C.currentBg or (hasFriends and C.friendBg or C.surface)
    local borderCol  = isCurrentServer and C.accent or (hasFriends and C.friendCol or C.border)
    local borderThk  = (isCurrentServer or hasFriends) and 1.5 or 1

    local card = btn({
        Text="", Size=UDim2.new(1,0,0,cardH),
        BackgroundColor3=cardBg, LayoutOrder=idx, ZIndex=13
    }, Scroll)
    corner(8, card); stroke(borderThk, borderCol, card)
    card.MouseEnter:Connect(function()
        card.BackgroundColor3 = isCurrentServer and C.currentBg or (hasFriends and C.friendBg or C.surfaceHov)
    end)
    card.MouseLeave:Connect(function() card.BackgroundColor3 = cardBg end)

    frame({
        Size=UDim2.new(0,3,0.65,0), Position=UDim2.new(0,0,0.175,0),
        BackgroundColor3=borderCol, ZIndex=14
    }, card)

    label({
        Text="Server #"..idx, Font=Enum.Font.GothamBold, TextSize=13,
        TextColor3=C.text, Position=UDim2.new(0,14,0,9),
        Size=UDim2.new(0.5,0,0,17), TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14
    }, card)

    if isCurrentServer then
        local badge = frame({
            Size=UDim2.new(0,88,0,16), Position=UDim2.new(0,110,0,11),
            BackgroundColor3=C.accentDark, ZIndex=15
        }, card)
        corner(4, badge)
        label({
            Text="● YOU'RE HERE", Font=Enum.Font.GothamBold, TextSize=9,
            TextColor3=C.accent, Size=UDim2.new(1,0,1,0),
            TextXAlignment=Enum.TextXAlignment.Center, ZIndex=16
        }, badge)
    elseif hasFriends then
        local badge = frame({
            Size=UDim2.new(0,84,0,16), Position=UDim2.new(0,110,0,11),
            BackgroundColor3=C.friendDark, ZIndex=15
        }, card)
        corner(4, badge)
        label({
            Text="● FRIEND HERE", Font=Enum.Font.GothamBold, TextSize=9,
            TextColor3=C.friendCol, Size=UDim2.new(1,0,1,0),
            TextXAlignment=Enum.TextXAlignment.Center, ZIndex=16
        }, badge)
    end

    local shortId = string.sub(tostring(server.id or "unknown"), 1, 18) .. "…"
    label({
        Text=shortId, Font=Enum.Font.Code, TextSize=10, TextColor3=C.dim,
        Position=UDim2.new(0,14,0,28), Size=UDim2.new(0.72,0,0,13),
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14
    }, card)

    if hasVisitorRow then
        local visitRow = frame({
            Size=UDim2.new(1,-80,0,22), Position=UDim2.new(0,14,0,45),
            BackgroundTransparency=1, ZIndex=14
        }, card)

        if isCurrentServer then
            local pfp = Instance.new("ImageLabel")
            pfp.Size             = UDim2.new(0,20,0,20)
            pfp.Position         = UDim2.new(0,0,0,1)
            pfp.BackgroundColor3 = C.surface
            pfp.BorderSizePixel  = 0
            pfp.Image            = "rbxthumb://type=AvatarHeadShot&id=" .. LocalPlayer.UserId .. "&w=48&h=48"
            pfp.ZIndex           = 15
            pfp.Parent           = visitRow
            corner(10, pfp)

            label({
                Text = LocalPlayer.Name .. " is visiting this server",
                Font=Enum.Font.Gotham, TextSize=10, TextColor3=C.accent,
                Position=UDim2.new(0,26,0,0), Size=UDim2.new(1,-26,1,0),
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15
            }, visitRow)

        else
            local displayCount = math.min(3, #friendsHere)
            for i = 1, displayCount do
                local pfp = Instance.new("ImageLabel")
                pfp.Size             = UDim2.new(0,20,0,20)
                pfp.Position         = UDim2.new(0, (i-1)*17, 0, 1)
                pfp.BackgroundColor3 = C.surface
                pfp.BorderSizePixel  = 0
                pfp.Image            = "rbxthumb://type=AvatarHeadShot&id="
                                       .. tostring(friendsHere[i].userId) .. "&w=48&h=48"
                pfp.ZIndex           = 15 + (displayCount - i)
                pfp.Parent           = visitRow
                corner(10, pfp)
            end

            local textX = displayCount * 17 + 6
            local visitText
            if #friendsHere == 1 then
                visitText = friendsHere[1].name .. " is visiting this server"
            elseif #friendsHere == 2 then
                visitText = friendsHere[1].name .. " & " .. friendsHere[2].name .. " are here"
            else
                visitText = friendsHere[1].name .. " & " .. (#friendsHere - 1) .. " friends are here"
            end

            label({
                Text = visitText,
                Font=Enum.Font.Gotham, TextSize=10, TextColor3=C.friendCol,
                Position=UDim2.new(0,textX,0,0), Size=UDim2.new(1,-textX,1,0),
                TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15
            }, visitRow)
        end
    end

    label({
        Text="👤 "..playing.."/"..maxP, Font=Enum.Font.GothamSemibold, TextSize=11,
        TextColor3=popCol(playing,maxP), Position=UDim2.new(0,14,1,-18),
        Size=UDim2.new(0,90,0,13), TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14
    }, card)
    label({
        Text="📶 "..ping.."ms", Font=Enum.Font.GothamSemibold, TextSize=11,
        TextColor3=pingCol(ping), Position=UDim2.new(0,112,1,-18),
        Size=UDim2.new(0,80,0,13), TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14
    }, card)

    local joinBtn = btn({
        Text             = isCurrentServer and "HERE" or "JOIN",
        Font             = Enum.Font.GothamBold, TextSize=11,
        TextColor3       = isCurrentServer and C.accent or Color3.fromRGB(255,255,255),
        BackgroundColor3 = isCurrentServer and C.accentDark or C.accentMid,
        Size=UDim2.new(0,58,0,28), Position=UDim2.new(1,-68,0.5,-14), ZIndex=15
    }, card)
    corner(7, joinBtn)

    if not isCurrentServer then
        joinBtn.MouseEnter:Connect(function() joinBtn.BackgroundColor3=C.accent end)
        joinBtn.MouseLeave:Connect(function() joinBtn.BackgroundColor3=C.accentMid end)
        joinBtn.MouseButton1Click:Connect(function()
            joinBtn.Text="…"; joinBtn.BackgroundColor3=C.dim
            local g = GAMES[selectedGameIndex]
            local ok2, _ = pcall(function()
                TeleportService:TeleportToPlaceInstance(g.placeId, server.id, LocalPlayer)
            end)
            if not ok2 then
                joinBtn.Text="ERR"; joinBtn.TextColor3=C.bad
                task.delay(2.5, function()
                    if joinBtn and joinBtn.Parent then
                        joinBtn.Text="JOIN"; joinBtn.TextColor3=Color3.fromRGB(255,255,255)
                        joinBtn.BackgroundColor3=C.accentMid
                    end
                end)
            end
        end)
    end
end

function doLoadServers()
    if isFetching then return end
    isFetching = true
    clearScroll()

    label({
        Text="⏳ Fetching servers & friends...", Font=Enum.Font.Gotham, TextSize=13,
        TextColor3=C.muted, Size=UDim2.new(1,0,0,50),
        TextXAlignment=Enum.TextXAlignment.Center, ZIndex=13
    }, Scroll)

    local g = GAMES[selectedGameIndex]
    setStatus("📡 Fetching servers & friends...", C.muted)

    local friendsDone, serversDone = false, false
    local serversResult, serversErr

    task.spawn(function()
        fetchFriendPresences()
        friendsDone = true
    end)
    task.spawn(function()
        serversResult, serversErr = fetchServers(g.placeId)
        serversDone = true
    end)

    while not (friendsDone and serversDone) do task.wait(0.05) end

    clearScroll()

    if not serversResult then
        label({ Text="❌ "..tostring(serversErr),
                Font=Enum.Font.Gotham, TextSize=11, TextColor3=C.bad,
                Size=UDim2.new(1,0,0,60), TextXAlignment=Enum.TextXAlignment.Center,
                TextWrapped=true, ZIndex=13 }, Scroll)
        setStatus("❌ "..tostring(serversErr), C.bad)
        isFetching=false; return
    end

    local servers = serversResult.data or {}
    if #servers == 0 then
        label({ Text="No servers found.\nRaw: "..string.sub(tostring(serversErr),1,200),
                Font=Enum.Font.Code, TextSize=10, TextColor3=C.warn,
                Size=UDim2.new(1,0,0,90), TextXAlignment=Enum.TextXAlignment.Left,
                TextWrapped=true, ZIndex=13 }, Scroll)
        setStatus("⚠ Empty — see debug text in list", C.warn)
    else
        table.sort(servers, function(a, b)
            local aMe  = tostring(a.id) == tostring(game.JobId)
            local bMe  = tostring(b.id) == tostring(game.JobId)
            local aFr  = friendPresenceMap[tostring(a.id)] ~= nil
            local bFr  = friendPresenceMap[tostring(b.id)] ~= nil
            if aMe ~= bMe then return aMe end
            if aFr ~= bFr then return aFr end
            return false
        end)

        local friendServerCount = 0
        for i, sv in ipairs(servers) do
            buildCard(sv, i)
            if i % 5 == 0 then task.wait() end
            if friendPresenceMap[tostring(sv.id)] then
                friendServerCount = friendServerCount + 1
            end
        end
        lastFetchTime = tick()

        local suffix = friendServerCount > 0
            and ("  •  👥 " .. friendServerCount .. " friend server" .. (friendServerCount > 1 and "s" or ""))
            or ""
        setStatus("✓ "..#servers.." servers  •  "..g.name..suffix, C.accent)
    end
    isFetching = false
end

RefreshBtn.MouseButton1Click:Connect(function()
    if isFetching then return end
    local elapsed = tick() - lastFetchTime
    if elapsed < COOLDOWN_SECS then
        local remaining = math.ceil(COOLDOWN_SECS - elapsed)
        setStatus("⏱ Wait " .. remaining .. "s before refreshing", C.warn)
        task.spawn(function()
            for t = remaining, 1, -1 do
                if RefreshBtn and RefreshBtn.Parent then
                    RefreshBtn.Text="↻  "..t.."s"
                    RefreshBtn.TextColor3=C.warn
                    RefreshBtn.BackgroundColor3=C.surface
                end
                task.wait(1)
            end
            if RefreshBtn and RefreshBtn.Parent then
                RefreshBtn.Text="↻  Refresh"
                RefreshBtn.TextColor3=C.accent
                RefreshBtn.BackgroundColor3=C.accentDark
                setStatus("✓ Ready to refresh", C.muted)
            end
        end)
        return
    end
    task.spawn(doLoadServers)
end)

task.spawn(function()
    setStatus("🔍 Fetching game info...", C.muted)
    for _, g in ipairs(GAMES) do
        if g.imageId and g.imageId ~= "" then
            local raw = tostring(g.imageId):gsub("rbxassetid://", "")
            g.imageId = "rbxassetid://" .. raw
        else
            g.imageId = "rbxthumb://type=Place&id=" .. tostring(g.placeId) .. "&w=256&h=144"
        end
    end
    DropThumb.Image = GAMES[selectedGameIndex].imageId
    rebuildDropdown()

    local placeIds = {}
    for _, g in ipairs(GAMES) do table.insert(placeIds, tostring(g.placeId)) end
    local details = fetchPlaceDetails(placeIds)
    if details then
        local lookup = {}
        for _, entry in ipairs(details) do
            if entry.placeId then lookup[tostring(entry.placeId)] = entry end
        end
        for _, g in ipairs(GAMES) do
            local entry = lookup[tostring(g.placeId)]
            if entry and entry.name and entry.name ~= "" then g.name = entry.name end
            if entry and entry.universeId and (g.imageId=="" or g.imageId:find("rbxthumb")) then
                g.imageId = "rbxthumb://type=GameThumbnail&id=" .. tostring(entry.universeId) .. "&w=256&h=144"
            end
        end
        DropLabel.Text  = GAMES[selectedGameIndex].name
        DropThumb.Image = GAMES[selectedGameIndex].imageId
        rebuildDropdown()
    end

    doLoadServers()
end)
