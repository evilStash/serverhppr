local function corner(r, p)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p
end
local function stroke(t, col, p)
    local s = Instance.new("UIStroke")
    s.Thickness = t or 1; s.Color = col or C.border
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = p
end
local function padding(a, b, c2, d, p)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop=UDim.new(0,a); pad.PaddingRight=UDim.new(0,b or a)
    pad.PaddingBottom=UDim.new(0,c2 or a); pad.PaddingLeft=UDim.new(0,d or b or a)
    pad.Parent = p
end
local function frame(props, parent)
    local f = Instance.new("Frame"); f.BorderSizePixel = 0
    for k,v in pairs(props) do pcall(function() f[k]=v end) end
    if parent then f.Parent = parent end; return f
end
local function label(props, parent)
    local l = Instance.new("TextLabel"); l.BackgroundTransparency=1; l.BorderSizePixel=0
    for k,v in pairs(props) do pcall(function() l[k]=v end) end
    if parent then l.Parent = parent end; return l
end
local function btn(props, parent)
    local b = Instance.new("TextButton"); b.BorderSizePixel=0; b.AutoButtonColor=false
    for k,v in pairs(props) do pcall(function() b[k]=v end) end
    if parent then b.Parent = parent end; return b
end

local Window = frame({
    Name="Window", Size=UDim2.new(0,390,0,520),
    Position=UDim2.new(0.5,-195,0.5,-260),
    BackgroundColor3=C.bg, ZIndex=10
}, ScreenGui)
